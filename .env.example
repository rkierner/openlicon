# Database
DATABASE_URL="postgresql://tirp:tirp_password@localhost:5432/tirp"

# Auth (NextAuth v5)
AUTH_SECRET=""  # generate with: openssl rand -base64 32
AUTH_URL="http://localhost:3000"

# Redis (BullMQ)
REDIS_URL="redis://localhost:6379"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="TIRP"

# Workday (mock by default)
WORKDAY_ADAPTER="mock"
# WORKDAY_TENANT_URL="https://your-tenant.workday.com"
# WORKDAY_USERNAME=""
# WORKDAY_PASSWORD=""

# Optional: set log level (debug | info | warn | error)
LOG_LEVEL="info"

# Encryption key for storing user integration credentials (Jira PATs, etc.)
ENCRYPTION_KEY=""  # generate with: openssl rand -hex 32
